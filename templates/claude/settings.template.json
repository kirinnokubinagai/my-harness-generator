{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "_comment_ja": "ハーネス用 Claude Code 設定。.my-harness/.config が存在するプロジェクトで自動的にユーザー入力を docs/talk/ にマスク済で記録するフックを登録する。",
  "hooks": {
    "UserPromptSubmit": [
      {
        "command": "bash __HARNESS_GENERATOR_DIR__/templates/hooks/log-user-prompt.sh"
      }
    ],
    "Stop": [
      {
        "command": "bash __HARNESS_GENERATOR_DIR__/templates/hooks/log-claude-output.sh"
      }
    ]
  }
}
