# daily-progress-bot — .env template
# Copy to .env on the OCI VM, fill in real values, chmod 600.

# Claude Pro/Max OAuth token. Run `claude login` on a desktop (browser
# required), then copy the value from ~/.claude/.credentials.json
# (look for the access_token field) into here. Tokens last ~90 days,
# rotate when the bot starts failing.
CLAUDE_CODE_OAUTH_TOKEN=

# Discord webhook URL.
# Discord server → Server Settings → Integrations → Webhooks → New Webhook
# → Copy Webhook URL. Looks like:
# https://discord.com/api/webhooks/123456.../abc...
DISCORD_WEBHOOK_URL=

# GitHub repo to summarize.
REPO_OWNER=your-github-user-or-org
REPO_NAME=your-repo

# GitHub token for the gh CLI. Use a fine-grained PAT with READ access to:
#   contents, issues, pull-requests, actions (read-only is enough)
# https://github.com/settings/personal-access-tokens
GH_TOKEN=

# Optional. "ja" or "en". Default: ja.
LANG_TAG=ja

# Optional. How many hours back to scan. Default: 24.
LOOKBACK_HOURS=24
