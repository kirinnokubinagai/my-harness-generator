# daily-progress-bot — .env template
# Copy to .env on the OCI VM, fill in real values, chmod 600.

# Which model to ask via the local CLIProxyAPI proxy on port 8317.
# CLIProxyAPI runs both Codex (ChatGPT subscription) and Claude Code
# (Claude Pro/Max subscription) OAuth providers simultaneously since 7.31.0;
# the model name selects which subscription CLIProxyAPI dispatches to.
#
# Available choices (verified 2026-05 availability):
#   claude-sonnet-4-6   — fast & capable Claude (recommended for cron use)
#   claude-opus-4-7     — most capable Claude (slower, heavier on quota)
#   claude-opus-4-6     — legacy but solid
#   gpt-5.5             — current OpenAI flagship (rolled out 2026-04-23)
#   gpt-5.4-mini        — fast & cheap OpenAI
AI_MODEL=claude-sonnet-4-6

# Optional override — if CLIProxyAPI is not on the default localhost:8317
# CLIPROXY_URL=http://localhost:8317

# Which service to post to. One of: discord | slack | teams
# Default: discord
NOTIFICATION_SERVICE=discord

# Webhook URL for the chosen service.
# Discord: Server Settings → Integrations → Webhooks → Copy Webhook URL
#          Looks like: https://discord.com/api/webhooks/123.../abc...
# Slack:   apps.slack.com → Your apps → Incoming Webhooks → Add New Webhook
#          Looks like: https://hooks.slack.com/services/T.../B.../xxx
# Teams:   Channel → ⋯ → Connectors → Incoming Webhook → Create
#          Looks like: https://outlook.office.com/webhook/...
NOTIFICATION_WEBHOOK_URL=

# GitHub repo to summarize.
REPO_OWNER=your-github-user-or-org
REPO_NAME=your-repo

# GitHub token for the gh CLI. Use a fine-grained PAT with READ access to:
#   contents, issues, pull-requests, actions (read-only is enough)
# https://github.com/settings/personal-access-tokens
GH_TOKEN=

# Optional. "ja" or "en". Default: ja.
LANG_TAG=ja

# Optional. How many hours back to scan. Default: 24.
LOOKBACK_HOURS=24
