{
  "$schema": "https://json.schemastore.org/claude-code-hooks",
  "description": "Logs user prompts and Claude responses to dev/docs/talk/ when run inside a my-harness project (no-op elsewhere).",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/log-user-prompt.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/log-claude-output.sh"
          }
        ]
      }
    ]
  }
}
